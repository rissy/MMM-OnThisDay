{# Wrapper #}
<div class="{{ config.textSize }}" style="max-width: {{ config.maxWidth }};">

    {% if events | length > 0 %}

        {% if config.carousel %}

            {# Progress bar #}
            {% if config.carouselProgress %}
                <style>
                    .MMM-OnThisDay progress::-webkit-progress-value {
                        transition: width {{ eventDisplayDuration - 0.5 }}s linear;
                    }
                </style>

                <progress id="mmm-otd-carousel-progress" value="0" max="1"></progress>
            {% endif %}

            {# Carousel mode #}
            {% set event = events[carouselIndex] %}
            <div id="mmm-otd-carousel-event" class="bright">{{ (event.text.charAt(0).toUpperCase() + event.text.slice(1)).trim() }}</div>

            {# List of years #}
            {% if (eventYears | length > 0) and hasYears %}

                <ul id="mmm-otd-carousel-years" class="event-year-list">
                    {% if eventYears | length > 0 %}

                        {% set total = eventYears | length %}
                        {% set current = carouselIndex %}

                        {% set start = current - 3 %}
                        {% set end = current + 3 %}

                        {% if start < 0 %}
                            {% set start = 0 %}
                            {% set end = 6 %}
                        {% endif %}

                        {% if end >= total %}
                            {% set end = total - 1 %}
                            {% set start = total - 7 %}
                        {% endif %}

                        {% if start < 0 %}{% set start = 0 %}{% endif %}

                        {% if start > 0 %}
                            <li class="event-year-dots light">...</li>
                        {% endif %}

                        {% for year in eventYears %}
                            {% if loop.index0 >= start and loop.index0 <= end and year != '*' %}
                                {% set fontWeight = 'bold' if loop.index0 == current else 'light' %}
                                <li class="event-year {{ fontWeight }}">{{ year }}</li>
                            {% endif %}
                        {% endfor %}

                        {% if end < total - 1 %}
                            <li class="event-year-dots light">...</li>
                        {% endif %}

                    {% endif %}
                </ul>

            {% endif %}

        {% else %}

            {# Normal mode #}
            <ul class="bright">
                {% for event in events %}
                    <li>{{ (event.text.charAt(0).toUpperCase() + event.text.slice(1)).trim() }}</li>
                {% endfor %}
            </ul>

        {% endif %}

    {% else %}

        {# No data #}
        {{ 'TEXT_NODATA' | translate }}

    {% endif %}

</div>
